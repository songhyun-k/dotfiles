{
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "hooks": {
    "PreToolUse": [
      {
        "_tag": "ccstatusline-managed",
        "hooks": [{ "type": "command", "command": "bunx -y ccstatusline@latest --hook" }],
        "matcher": "Skill"
      }
    ],
    "UserPromptSubmit": [
      {
        "_tag": "ccstatusline-managed",
        "hooks": [{ "type": "command", "command": "bunx -y ccstatusline@latest --hook" }]
      }
    ]
  }
}
